{
  "name": "@marwansaab/obsidian-modified-mcp-server",
  "version": "0.5.0",
  "description": "Personal fork of @connorbritain/obsidian-mcp-server. TypeScript MCP server for Obsidian with wrapper-side mitigations of upstream limitations — first concrete change is re-enabling patch_content under a structural-only path validator.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "obsidian-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marwansaab/obsidian-modified-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "model-context-protocol",
    "ai",
    "llm",
    "knowledge-management",
    "graph-analysis",
    "semantic-search",
    "fork"
  ],
  "author": "Marwan Saab",
  "contributors": [
    { "name": "Connor Britain", "url": "https://github.com/ConnorBritain" }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/marwansaab/obsidian-modified-mcp-server/issues"
  },
  "homepage": "https://github.com/marwansaab/obsidian-modified-mcp-server#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.7",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.1",
    "graphology-metrics": "^2.3.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "graphology-utils": "^2.3.1",
    "lru-cache": "^11.0.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsonc": "^2.15.0",
    "eslint-plugin-n": "^17.10.3",
    "eslint-plugin-promise": "^7.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "nock": "14.0.13",
    "tsup": "^8.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.6.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
